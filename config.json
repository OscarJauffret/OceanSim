{
  "window": {
    "width": 800,
    "height": 600,
    "title": "Ocean Simulation"
  },

  "shaders": {
    "vertex": "../shaders/base.vert",
    "fragment": "../shaders/base.frag"
  },

  "ocean": {
    "resolution": 128,
    "size": 50.0,
    "wireframe": true
  },

